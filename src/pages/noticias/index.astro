---
import Layout from "../layouts/Layout.astro";

// Esta línea va a la carpeta del CMS y trae todos los archivos de noticias
const noticias = await Astro.glob<any>("../content/noticias/*.md");
---

<Layout>
    <main class="container mx-auto pt-32 px-5 min-h-screen">
        <h1 class="text-4xl font-bold text-gray-900 mb-10">
            Noticias Relevantes
        </h1>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {/* Aquí Astro toma cada noticia y crea una tarjeta para ella */}
            {
                noticias.map((noticia: any) => (
                    <article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
                        {noticia.frontmatter.image && (
                            <img
                                src={noticia.frontmatter.image}
                                alt={noticia.frontmatter.title}
                                class="w-full h-48 object-cover"
                            />
                        )}
                        <div class="p-6">
                            <p class="text-sm text-umb-verde font-semibold mb-2">
                                {new Date(
                                    noticia.frontmatter.date,
                                ).toLocaleDateString("es-MX")}
                            </p>
                            <h2 class="text-xl font-bold text-gray-800 mb-3">
                                {noticia.frontmatter.title}
                            </h2>
                            {/* AQUÍ ESTÁ EL ENLACE CONECTADO */}
                            <a
                                href={`/noticias/${noticia.file.split("/").pop().split(".").shift()}`}
                                class="group inline-block mt-2"
                            >
                                <p class="text-gray-600 font-medium group-hover:text-umb-verde transition-colors">
                                    Leer artículo &rarr;
                                </p>
                            </a>
                        </div>
                    </article>
                ))
            }
        </div>
    </main>
</Layout>
