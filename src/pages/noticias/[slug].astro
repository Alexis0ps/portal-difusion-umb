---
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
    // 🔥 LA SOLUCIÓN: Usar import.meta.glob (Vite nativo) en lugar de Astro.glob
    const archivos = import.meta.glob("../../content/noticias/*.md", {
        eager: true,
    });

    // Mapeamos cada archivo encontrado para crear su ruta
    return Object.keys(archivos).map((ruta) => {
        const post = archivos[ruta];

        // Extraemos el nombre exacto del archivo (ej. "mi-noticia")
        const slug = ruta.split("/").pop().replace(".md", "");

        return {
            params: { slug },
            props: { post },
        };
    });
}

const { Content, frontmatter } = Astro.props.post as any;
---

<Layout>
    <article class="container mx-auto pt-32 px-5 max-w-4xl min-h-screen">
        {
            frontmatter.image && (
                <img
                    src={frontmatter.image}
                    alt={frontmatter.title}
                    class="w-full h-[400px] object-cover rounded-3xl shadow-lg mb-10"
                />
            )
        }

        <header class="mb-8">
            <p class="text-umb-verde font-bold mb-2">
                {new Date(frontmatter.date).toLocaleDateString("es-MX")}
            </p>
            <h1
                class="text-4xl md:text-5xl font-extrabold text-gray-900 leading-tight"
            >
                {frontmatter.title}
            </h1>
        </header>

        <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed">
            <Content />
        </div>
    </article>
</Layout>
