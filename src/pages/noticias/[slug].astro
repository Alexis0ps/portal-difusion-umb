---
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
    const archivos = import.meta.glob("../../content/noticias/*.md", {
        eager: true,
    });

    return Object.keys(archivos).map((ruta) => {
        const post = archivos[ruta];
        const slug = ruta.split("/").pop().replace(".md", "");

        return {
            params: { slug },
            props: { post },
        };
    });
}

const { Content, frontmatter } = Astro.props.post as any;
---

<Layout>
    <div
        class="fixed inset-0 z-[-1] overflow-hidden bg-white pointer-events-none"
    >
        <div
            class="absolute top-[-10%] left-[-10%] w-[40rem] h-[40rem] bg-green-50 rounded-full mix-blend-multiply filter blur-3xl opacity-70"
        >
        </div>
    </div>

    <main class="container mx-auto px-5 pt-32 pb-24 relative z-10 max-w-4xl">
        <article
            class="bg-white rounded-[2.5rem] shadow-xl border border-gray-100 p-6 md:p-12"
        >
            <header class="text-center mb-10">
                <span
                    class="inline-block bg-green-100 text-umb-verde font-bold text-sm tracking-wider uppercase px-4 py-1.5 rounded-full mb-6"
                >
                    {
                        new Date(frontmatter.date).toLocaleDateString("es-MX", {
                            day: "numeric",
                            month: "long",
                            year: "numeric",
                        })
                    }
                </span>
                <h1
                    class="text-3xl md:text-5xl font-extrabold text-gray-900 leading-tight mb-8"
                >
                    {frontmatter.title}
                </h1>

                {
                    frontmatter.image && (
                        <img
                            src={frontmatter.image}
                            alt={frontmatter.title}
                            class="w-full h-[400px] object-cover rounded-3xl shadow-md"
                        />
                    )
                }
            </header>

            <div
                class="prose prose-lg max-w-none text-gray-600 leading-relaxed prose-headings:text-gray-900 prose-headings:font-bold prose-a:text-umb-verde hover:prose-a:text-emerald-700 prose-img:rounded-2xl mx-auto px-4"
            >
                <Content />
            </div>

            <div class="mt-16 pt-8 border-t border-gray-100 text-center">
                <a
                    href="/noticias"
                    class="inline-flex items-center justify-center bg-umb-verde text-white font-bold px-8 py-3 rounded-full hover:bg-emerald-800 transition-colors shadow-lg shadow-green-500/30"
                >
                    &larr; Volver a noticias
                </a>
            </div>
        </article>
    </main>
</Layout>
