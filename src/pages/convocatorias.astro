---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <main class="min-h-screen pt-32 px-6 flex flex-col items-center">
        <h1 class="text-5xl font-bold text-umb-verde mb-8 text-center">
            Convocatorias Vigentes
        </h1>
        <div
            class="bg-white/5 border border-white/10 p-8 rounded-3xl backdrop-blur-md max-w-2xl text-center"
        >
            <span class="text-4xl mb-4 block">📅</span>
            <p class="text-xl opacity-80">
                Las convocatorias para el próximo ciclo escolar se publicarán en
                esta sección. Mantente al pendiente.
            </p>
        </div>
    </main>
</Layout>
