---
import Layout from "../../layouts/Layout.astro";

const archivos = import.meta.glob("../../content/noticias/*.md", {
    eager: true,
});
const todasLasNoticias = Object.keys(archivos).map((ruta) => ({
    ...(archivos[ruta] as any),
    file: ruta,
}));

const noticiasRecientes = todasLasNoticias.sort(
    (a: any, b: any) =>
        new Date(b.frontmatter.date).valueOf() -
        new Date(a.frontmatter.date).valueOf(),
);

const noticiaDestacada = noticiasRecientes[0];
const restoNoticias = noticiasRecientes.slice(1);
---

<Layout>
    <div class="bg-[#121212] min-h-screen text-gray-300 pt-28 pb-20 font-sans">
        <div class="max-w-2xl mx-auto px-6">
            <div class="flex justify-between items-center mb-8">
                <h1 class="text-4xl font-serif text-white tracking-wide">
                    Noticias
                </h1>
                <div class="flex gap-4">
                    <div
                        class="w-10 h-10 rounded-full bg-zinc-900 flex items-center justify-center text-white cursor-pointer hover:bg-zinc-800 transition"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"
                            ></path></svg
                        >
                    </div>
                    <div
                        class="w-10 h-10 rounded-full bg-zinc-900 flex items-center justify-center text-white cursor-pointer hover:bg-zinc-800 transition relative"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"
                            ></path></svg
                        >
                        <span
                            class="absolute top-2 right-2 w-2 h-2 bg-umb-verde rounded-full"
                        ></span>
                    </div>
                </div>
            </div>

            <div class="flex gap-3 mb-8 overflow-x-auto pb-2 scrollbar-hide">
                <span
                    class="px-5 py-2 rounded-full bg-white text-black font-semibold text-sm"
                    >Destacado</span
                >
                <span
                    class="px-5 py-2 rounded-full border border-gray-700 text-gray-300 text-sm hover:border-gray-500 cursor-pointer"
                    >Reciente</span
                >
                <span
                    class="px-5 py-2 rounded-full border border-gray-700 text-gray-300 text-sm hover:border-gray-500 cursor-pointer"
                    >Comunidad</span
                >
            </div>

            {
                noticiaDestacada && (
                    <a
                        href={`/noticias/${noticiaDestacada.file.split("/").pop().replace(".md", "")}`}
                        class="block mb-12 group border-b border-zinc-800 pb-10"
                    >
                        <div class="w-full h-64 md:h-80 rounded-[2rem] overflow-hidden mb-6">
                            {noticiaDestacada.frontmatter.image ? (
                                <img
                                    src={noticiaDestacada.frontmatter.image}
                                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                                />
                            ) : (
                                <div class="w-full h-full bg-zinc-800" />
                            )}
                        </div>
                        <div class="flex gap-3 mb-3">
                            <span class="px-3 py-1 rounded-full border border-gray-700 text-xs text-gray-400">
                                #1 Tendencia
                            </span>
                            <span class="px-3 py-1 rounded-full border border-gray-700 text-xs text-gray-400">
                                Institucional
                            </span>
                        </div>
                        <h2 class="text-3xl font-serif text-white mb-4 leading-snug group-hover:text-umb-verde transition-colors">
                            {noticiaDestacada.frontmatter.title}
                        </h2>

                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-3 text-sm text-gray-400">
                                <div class="w-8 h-8 rounded-full bg-umb-verde text-white flex items-center justify-center font-bold text-xs shadow-lg shadow-green-900/50">
                                    U
                                </div>
                                <span class="font-medium text-gray-300">
                                    Difusión UMB
                                </span>
                                <span>•</span>
                                <span>
                                    {new Date(
                                        noticiaDestacada.frontmatter.date,
                                    ).toLocaleDateString("es-MX", {
                                        day: "numeric",
                                        month: "short",
                                    })}
                                </span>
                            </div>
                            <div class="w-12 h-12 rounded-full bg-umb-verde text-white flex items-center justify-center group-hover:scale-110 transition-transform">
                                <svg
                                    class="w-5 h-5 transform -rotate-45"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2.5"
                                        d="M14 5l7 7m0 0l-7 7m7-7H3"
                                    />
                                </svg>
                            </div>
                        </div>
                    </a>
                )
            }

            <div class="flex flex-col gap-8">
                {
                    restoNoticias.map((noticia: any) => (
                        <a
                            href={`/noticias/${noticia.file.split("/").pop().replace(".md", "")}`}
                            class="flex items-center gap-5 group"
                        >
                            <div class="flex flex-col justify-center flex-grow">
                                <h3 class="text-xl font-serif text-white mb-3 leading-snug group-hover:text-umb-verde transition-colors line-clamp-3">
                                    {noticia.frontmatter.title}
                                </h3>
                                <div class="flex items-center gap-2 text-xs text-gray-400">
                                    <span class="font-medium text-gray-300">
                                        Difusión UMB
                                    </span>
                                    <span>•</span>
                                    <span>
                                        {new Date(
                                            noticia.frontmatter.date,
                                        ).toLocaleDateString("es-MX", {
                                            day: "numeric",
                                            month: "short",
                                        })}
                                    </span>
                                </div>
                            </div>
                            <div class="w-28 h-28 md:w-32 md:h-32 shrink-0 rounded-3xl overflow-hidden relative">
                                {noticia.frontmatter.image ? (
                                    <img
                                        src={noticia.frontmatter.image}
                                        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                                    />
                                ) : (
                                    <div class="w-full h-full bg-zinc-800" />
                                )}
                                <div class="absolute bottom-2 right-2 w-8 h-8 rounded-full bg-white text-black flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                                    <svg
                                        class="w-3 h-3 transform -rotate-45"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="3"
                                            d="M14 5l7 7m0 0l-7 7m7-7H3"
                                        />
                                    </svg>
                                </div>
                            </div>
                        </a>
                    ))
                }
            </div>
        </div>
    </div>
</Layout>
