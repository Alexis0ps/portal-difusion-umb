---
import Layout from "../../layouts/Layout.astro";

const archivos = import.meta.glob("../../content/noticias/*.md", {
    eager: true,
});
const todasLasNoticias = Object.keys(archivos).map((ruta) => ({
    ...(archivos[ruta] as any),
    file: ruta,
}));

const noticiasRecientes = todasLasNoticias.sort(
    (a: any, b: any) =>
        new Date(b.frontmatter.date).valueOf() -
        new Date(a.frontmatter.date).valueOf(),
);

const noticiaDestacada = noticiasRecientes[0];
const restoNoticias = noticiasRecientes.slice(1);
---

<Layout>
    <div class="bg-slate-50 min-h-screen text-gray-800 pt-28 pb-20 font-sans">
        <div class="max-w-2xl mx-auto px-6">
            <div class="flex justify-between items-center mb-8">
                <h1
                    class="text-4xl font-serif text-gray-900 font-extrabold tracking-wide"
                >
                    Noticias
                </h1>
                <div class="flex gap-4">
                    <div
                        class="w-11 h-11 rounded-full bg-white shadow-sm border border-gray-200 flex items-center justify-center text-gray-600 cursor-pointer hover:text-umb-verde hover:bg-green-50 transition"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"
                            ></path></svg
                        >
                    </div>
                    <div
                        class="w-11 h-11 rounded-full bg-white shadow-sm border border-gray-200 flex items-center justify-center text-gray-600 cursor-pointer hover:text-umb-verde hover:bg-green-50 transition relative"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"
                            ></path></svg
                        >
                        <span
                            class="absolute top-2 right-2 w-2.5 h-2.5 bg-umb-verde rounded-full border-2 border-white"
                        ></span>
                    </div>
                </div>
            </div>

            <div class="flex gap-3 mb-8 overflow-x-auto pb-4 scrollbar-hide">
                <span
                    class="px-6 py-2.5 rounded-full bg-gray-900 text-white font-bold text-sm shadow-md"
                    >Destacado</span
                >
                <span
                    class="px-6 py-2.5 rounded-full bg-white border border-gray-200 text-gray-600 font-semibold text-sm hover:border-umb-verde hover:text-umb-verde cursor-pointer shadow-sm transition-colors"
                    >Reciente</span
                >
                <span
                    class="px-6 py-2.5 rounded-full bg-white border border-gray-200 text-gray-600 font-semibold text-sm hover:border-umb-verde hover:text-umb-verde cursor-pointer shadow-sm transition-colors"
                    >Comunidad</span
                >
            </div>

            {
                noticiaDestacada && (
                    <a
                        href={`/noticias/${noticiaDestacada.file.split("/").pop().replace(".md", "")}`}
                        class="block mb-12 group bg-white rounded-[2.5rem] p-4 shadow-xl shadow-gray-200/50 border border-gray-100 transition-all hover:-translate-y-1"
                    >
                        <div class="w-full h-64 md:h-[350px] rounded-[2rem] overflow-hidden mb-6">
                            {noticiaDestacada.frontmatter.image ? (
                                <img
                                    src={noticiaDestacada.frontmatter.image}
                                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                                />
                            ) : (
                                <div class="w-full h-full bg-gray-100 flex items-center justify-center">
                                    <span class="text-5xl opacity-20">📰</span>
                                </div>
                            )}
                        </div>
                        <div class="px-2">
                            <div class="flex gap-3 mb-4">
                                <span class="px-4 py-1.5 rounded-full bg-green-50 border border-green-100 text-xs font-bold text-umb-verde">
                                    #1 Tendencia
                                </span>
                                <span class="px-4 py-1.5 rounded-full bg-gray-50 border border-gray-200 text-xs font-semibold text-gray-500">
                                    Institucional
                                </span>
                            </div>
                            <h2 class="text-3xl font-serif text-gray-900 mb-6 font-extrabold leading-snug group-hover:text-umb-verde transition-colors">
                                {noticiaDestacada.frontmatter.title}
                            </h2>

                            <div class="flex items-center justify-between pb-2">
                                <div class="flex items-center gap-3 text-sm text-gray-500">
                                    <div class="w-9 h-9 rounded-full bg-umb-verde text-white flex items-center justify-center font-bold text-xs shadow-md">
                                        U
                                    </div>
                                    <span class="font-bold text-gray-700">
                                        Difusión UMB
                                    </span>
                                    <span>•</span>
                                    <span class="font-medium text-gray-500">
                                        {new Date(
                                            noticiaDestacada.frontmatter.date,
                                        ).toLocaleDateString("es-MX", {
                                            day: "numeric",
                                            month: "short",
                                        })}
                                    </span>
                                </div>
                                <div class="w-12 h-12 rounded-full bg-gray-50 border border-gray-100 text-gray-600 flex items-center justify-center group-hover:bg-umb-verde group-hover:text-white group-hover:border-umb-verde transition-all duration-300 shadow-sm">
                                    <svg
                                        class="w-5 h-5 transform -rotate-45"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2.5"
                                            d="M14 5l7 7m0 0l-7 7m7-7H3"
                                        />
                                    </svg>
                                </div>
                            </div>
                        </div>
                    </a>
                )
            }

            <div class="flex flex-col gap-5">
                {
                    restoNoticias.map((noticia: any) => (
                        <a
                            href={`/noticias/${noticia.file.split("/").pop().replace(".md", "")}`}
                            class="flex items-center gap-5 group bg-white p-3 rounded-3xl shadow-sm border border-gray-100 hover:shadow-lg transition-all hover:-translate-y-1"
                        >
                            <div class="w-28 h-28 md:w-32 md:h-32 shrink-0 rounded-[1.5rem] overflow-hidden relative">
                                {noticia.frontmatter.image ? (
                                    <img
                                        src={noticia.frontmatter.image}
                                        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                                    />
                                ) : (
                                    <div class="w-full h-full bg-gray-100 flex items-center justify-center">
                                        <span class="text-3xl opacity-20">
                                            📰
                                        </span>
                                    </div>
                                )}
                                <div class="absolute bottom-2 right-2 w-8 h-8 rounded-full bg-umb-verde text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity shadow-md">
                                    <svg
                                        class="w-4 h-4 transform -rotate-45"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="3"
                                            d="M14 5l7 7m0 0l-7 7m7-7H3"
                                        />
                                    </svg>
                                </div>
                            </div>

                            <div class="flex flex-col justify-center flex-grow pr-3">
                                <h3 class="text-lg md:text-xl font-serif text-gray-900 font-bold mb-2 leading-snug group-hover:text-umb-verde transition-colors line-clamp-2">
                                    {noticia.frontmatter.title}
                                </h3>
                                <div class="flex items-center gap-2 text-xs">
                                    <span class="font-bold text-gray-700">
                                        UMB
                                    </span>
                                    <span class="text-gray-300">•</span>
                                    <span class="font-medium text-gray-500">
                                        {new Date(
                                            noticia.frontmatter.date,
                                        ).toLocaleDateString("es-MX", {
                                            day: "numeric",
                                            month: "short",
                                        })}
                                    </span>
                                </div>
                            </div>
                        </a>
                    ))
                }
            </div>
        </div>
    </div>
</Layout>
