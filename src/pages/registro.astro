---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <main
        class="min-h-screen pt-32 pb-12 px-6 flex flex-col items-center relative overflow-hidden bg-white"
    >
        <div
            class="absolute -top-20 -left-20 w-[500px] h-[500px] bg-[#7FB239]/10 rounded-full blur-[100px] -z-10"
        >
        </div>
        <div
            class="absolute bottom-0 right-0 w-[600px] h-[600px] bg-[#7FB239]/10 rounded-full blur-[120px] -z-10"
        >
        </div>

        <div class="w-full max-w-2xl z-10">
            <div class="text-center mb-10">
                <h1
                    class="text-5xl md:text-6xl font-extrabold text-[#7FB239] mb-4 tracking-tighter leading-tight"
                >
                    Registro de Aspirantes
                </h1>
                <p class="text-lg text-gray-600 font-medium leading-relaxed">
                    Déjanos tus datos para iniciar tu proceso de admisión a la
                    Universidad Mexiquense del Bicentenario.
                </p>
            </div>

            <div
                class="bg-white border border-gray-100 p-8 md:p-10 rounded-[2.5rem] shadow-[0_20px_40px_rgba(0,0,0,0.06)]"
            >
                <form class="flex flex-col gap-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="flex flex-col gap-2">
                            <label
                                for="nombre"
                                class="text-sm font-extrabold text-gray-800 tracking-wide"
                                >Nombre(s) *</label
                            >
                            <input
                                type="text"
                                id="nombre"
                                required
                                placeholder="Ej. Juan"
                                class="bg-gray-50 border border-gray-200 rounded-2xl px-5 py-4 text-gray-900 placeholder-gray-400 font-medium focus:outline-none focus:border-[#7FB239] focus:ring-4 focus:ring-[#7FB239]/15 transition-all"
                            />
                        </div>
                        <div class="flex flex-col gap-2">
                            <label
                                for="apellidos"
                                class="text-sm font-extrabold text-gray-800 tracking-wide"
                                >Apellidos *</label
                            >
                            <input
                                type="text"
                                id="apellidos"
                                required
                                placeholder="Ej. Pérez García"
                                class="bg-gray-50 border border-gray-200 rounded-2xl px-5 py-4 text-gray-900 placeholder-gray-400 font-medium focus:outline-none focus:border-[#7FB239] focus:ring-4 focus:ring-[#7FB239]/15 transition-all"
                            />
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="flex flex-col gap-2">
                            <label
                                for="correo"
                                class="text-sm font-extrabold text-gray-800 tracking-wide"
                                >Correo Electrónico *</label
                            >
                            <input
                                type="email"
                                id="correo"
                                required
                                placeholder="juan@correo.com"
                                class="bg-gray-50 border border-gray-200 rounded-2xl px-5 py-4 text-gray-900 placeholder-gray-400 font-medium focus:outline-none focus:border-[#7FB239] focus:ring-4 focus:ring-[#7FB239]/15 transition-all"
                            />
                        </div>
                        <div class="flex flex-col gap-2">
                            <label
                                for="telefono"
                                class="text-sm font-extrabold text-gray-800 tracking-wide"
                                >Teléfono Celular *</label
                            >
                            <input
                                type="tel"
                                id="telefono"
                                required
                                placeholder="10 dígitos"
                                class="bg-gray-50 border border-gray-200 rounded-2xl px-5 py-4 text-gray-900 placeholder-gray-400 font-medium focus:outline-none focus:border-[#7FB239] focus:ring-4 focus:ring-[#7FB239]/15 transition-all"
                            />
                        </div>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label
                            for="curp"
                            class="text-sm font-extrabold text-gray-800 tracking-wide"
                            >CURP *</label
                        >
                        <input
                            type="text"
                            id="curp"
                            required
                            maxlength="18"
                            placeholder="Ingresa tus 18 caracteres"
                            class="bg-gray-50 border border-gray-200 rounded-2xl px-5 py-4 text-gray-900 placeholder-gray-400 font-medium focus:outline-none focus:border-[#7FB239] focus:ring-4 focus:ring-[#7FB239]/15 transition-all uppercase"
                        />
                    </div>

                    <div class="flex flex-col gap-2">
                        <label
                            for="carrera"
                            class="text-sm font-extrabold text-gray-800 tracking-wide"
                            >Carrera de Interés *</label
                        >
                        <select
                            id="carrera"
                            required
                            class="bg-gray-50 border border-gray-200 rounded-2xl px-5 py-4 text-gray-900 font-medium focus:outline-none focus:border-[#7FB239] focus:ring-4 focus:ring-[#7FB239]/15 transition-all appearance-none cursor-pointer"
                        >
                            <option value="" disabled selected
                                >Selecciona una opción...</option
                            >
                            <option value="sistemas"
                                >Ingeniería en Sistemas Computacionales</option
                            >
                            <option value="administracion"
                                >Licenciatura en Administración</option
                            >
                            <option value="enfermeria"
                                >Licenciatura en Enfermería</option
                            >
                        </select>
                    </div>

                    <button
                        type="submit"
                        class="mt-6 w-full bg-[#7FB239] text-white font-extrabold text-lg py-4 rounded-full shadow-[0_10px_20px_rgba(127,178,57,0.3)] hover:shadow-[0_15px_25px_rgba(127,178,57,0.4)] hover:-translate-y-1 transition-all duration-300 flex items-center justify-center gap-2 group"
                    >
                        Enviar Registro
                        <span
                            class="group-hover:translate-x-1 transition-transform"
                            >📝</span
                        >
                    </button>
                </form>
            </div>
        </div>
    </main>
</Layout>
