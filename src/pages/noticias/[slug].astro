---
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
    const archivos = import.meta.glob("../../content/noticias/*.md", {
        eager: true,
    });

    return Object.keys(archivos).map((ruta) => {
        const post = archivos[ruta];
        const slug = ruta.split("/").pop().replace(".md", "");
        return { params: { slug }, props: { post } };
    });
}

const { Content, frontmatter } = Astro.props.post as any;
---

<Layout>
    <div class="bg-slate-50 min-h-screen text-gray-800 font-sans pb-24 pt-28">
        <div class="max-w-2xl mx-auto px-6">
            <div class="flex justify-between items-center mb-8">
                <a
                    href="/noticias"
                    class="w-12 h-12 rounded-full bg-white flex items-center justify-center text-gray-700 hover:text-umb-verde hover:bg-green-50 border border-gray-200 transition shadow-sm"
                >
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M15 19l-7-7 7-7"></path></svg
                    >
                </a>
                <div class="flex gap-4">
                    <button
                        class="w-12 h-12 rounded-full bg-white flex items-center justify-center text-gray-700 hover:text-umb-verde hover:bg-green-50 border border-gray-200 transition shadow-sm"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"
                            ></path></svg
                        >
                    </button>
                    <button
                        class="w-12 h-12 rounded-full bg-white flex items-center justify-center text-gray-700 hover:text-umb-verde hover:bg-green-50 border border-gray-200 transition shadow-sm"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"
                            ></path></svg
                        >
                    </button>
                </div>
            </div>

            {
                frontmatter.image && (
                    <div class="w-full h-[300px] md:h-[450px] rounded-[2.5rem] overflow-hidden mb-10 shadow-xl shadow-gray-200/50 bg-white border-8 border-white">
                        <img
                            src={frontmatter.image}
                            alt={frontmatter.title}
                            class="w-full h-full object-cover rounded-[1.5rem]"
                        />
                    </div>
                )
            }

            <div
                class="flex flex-wrap justify-between items-center text-xs font-bold tracking-wider uppercase mb-6 gap-4"
            >
                <span
                    class="text-umb-verde bg-green-50 px-4 py-2 rounded-full border border-green-100"
                    >#1 en Tendencia / UMB</span
                >
                <span
                    class="text-gray-500 flex items-center gap-1.5 bg-white border border-gray-200 px-4 py-2 rounded-full shadow-sm"
                >
                    <svg
                        class="w-4 h-4 text-umb-verde"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                        ></path></svg
                    >
                    Publicado
                </span>
            </div>

            <h1
                class="text-4xl md:text-5xl font-serif text-gray-900 leading-[1.15] mb-8 font-extrabold tracking-tight"
            >
                {frontmatter.title}
            </h1>

            <div
                class="flex justify-between items-center mb-10 pb-8 border-b border-gray-200"
            >
                <div class="flex items-center gap-3">
                    <div
                        class="w-11 h-11 rounded-full bg-umb-verde text-white flex items-center justify-center font-bold shadow-lg shadow-green-500/30"
                    >
                        U
                    </div>
                    <span class="text-gray-900 font-bold text-sm md:text-base"
                        >Difusión UMB</span
                    >
                </div>
                <div
                    class="text-sm text-gray-500 font-semibold bg-white px-4 py-2 rounded-full border border-gray-200 shadow-sm"
                >
                    {
                        new Date(frontmatter.date).toLocaleDateString("es-MX", {
                            day: "numeric",
                            month: "short",
                            year: "numeric",
                        })
                    }
                </div>
            </div>

            <div
                class="prose prose-lg md:prose-xl max-w-none prose-p:text-gray-600 prose-headings:font-serif prose-headings:text-gray-900 prose-headings:font-extrabold prose-a:text-umb-verde leading-relaxed"
            >
                <Content />
            </div>

            <div
                class="fixed bottom-6 left-1/2 transform -translate-x-1/2 bg-white/95 backdrop-blur-md border border-gray-200 px-8 py-4 rounded-full flex gap-10 items-center shadow-[0_20px_50px_-12px_rgba(0,0,0,0.15)] z-50"
            >
                <button
                    class="text-gray-400 hover:text-umb-verde hover:scale-110 transition-all duration-300 flex flex-col items-center gap-1"
                >
                    <svg
                        class="w-6 h-6"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2.5"
                            d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                        ></path></svg
                    >
                </button>
                <button
                    class="text-gray-400 hover:text-umb-verde hover:scale-110 transition-all duration-300 flex flex-col items-center gap-1"
                >
                    <svg
                        class="w-6 h-6"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2.5"
                            d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
                        ></path></svg
                    >
                </button>
                <button
                    class="text-gray-400 hover:text-umb-verde hover:scale-110 transition-all duration-300 flex flex-col items-center gap-1"
                >
                    <svg
                        class="w-6 h-6 transform -rotate-45"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2.5"
                            d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg
                    >
                </button>
            </div>
        </div>
    </div>
</Layout>
