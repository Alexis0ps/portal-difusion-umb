---
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
    // 1. Ruta corregida y <any> eliminado
    const posts = await Astro.glob("../../content/noticias/*.md");

    // 2. Ahora usamos la variable correcta "posts"
    return posts.map((post) => ({
        params: {
            slug: post.file.split("/").pop().split(".").shift(),
        },
        props: { post },
    }));
}

const { Content, frontmatter } = Astro.props.post;
---

<Layout>
    <article class="container mx-auto pt-32 px-5 max-w-4xl min-h-screen">
        {
            frontmatter.image && (
                <img
                    src={frontmatter.image}
                    alt={frontmatter.title}
                    class="w-full h-[400px] object-cover rounded-3xl shadow-lg mb-10"
                />
            )
        }

        <header class="mb-8">
            <p class="text-umb-verde font-bold mb-2">
                {new Date(frontmatter.date).toLocaleDateString("es-MX")}
            </p>
            <h1
                class="text-4xl md:text-5xl font-extrabold text-gray-900 leading-tight"
            >
                {frontmatter.title}
            </h1>
        </header>

        <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed">
            <Content />
        </div>
    </article>
</Layout>
s
