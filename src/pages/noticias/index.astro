---
import Layout from "../../layouts/Layout.astro";

const archivos = import.meta.glob("../../content/noticias/*.md", {
    eager: true,
});
const todasLasNoticias = Object.keys(archivos).map((ruta) => ({
    ...(archivos[ruta] as any),
    file: ruta,
}));

const noticiasRecientes = todasLasNoticias.sort(
    (a: any, b: any) =>
        new Date(b.frontmatter.date).valueOf() -
        new Date(a.frontmatter.date).valueOf(),
);
---

<Layout>
    <div
        class="fixed inset-0 z-[-1] overflow-hidden bg-white pointer-events-none"
    >
        <div
            class="absolute top-[-10%] left-[-10%] w-[40rem] h-[40rem] bg-green-50 rounded-full mix-blend-multiply filter blur-3xl opacity-70"
        >
        </div>
        <div
            class="absolute bottom-[-10%] right-[-10%] w-[30rem] h-[30rem] bg-green-50 rounded-full mix-blend-multiply filter blur-3xl opacity-70"
        >
        </div>
    </div>

    <main class="container mx-auto px-5 pt-36 pb-24 relative z-10 max-w-6xl">
        <div class="text-center mb-20">
            <span
                class="inline-block py-1.5 px-5 rounded-full bg-green-100 text-umb-verde font-bold text-sm tracking-widest uppercase mb-4"
            >
                Mantente Informado
            </span>
            <h1
                class="text-5xl md:text-6xl font-extrabold text-gray-900 mb-6 tracking-tight"
            >
                Noticias <span class="text-umb-verde">UMB</span>
            </h1>
            <p class="text-gray-600 max-w-2xl mx-auto text-lg">
                Descubre las últimas novedades, eventos y avisos importantes de
                la Universidad Mexiquense del Bicentenario.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {
                noticiasRecientes.map((noticia: any) => (
                    <a
                        href={`/noticias/${noticia.file.split("/").pop().replace(".md", "")}`}
                        class="block group bg-white rounded-3xl shadow-lg hover:shadow-2xl border border-gray-100 overflow-hidden transition-all duration-300 hover:-translate-y-2 flex flex-col h-full"
                    >
                        <div class="relative h-56 overflow-hidden p-3 pb-0">
                            {noticia.frontmatter.image ? (
                                <img
                                    src={noticia.frontmatter.image}
                                    alt={noticia.frontmatter.title}
                                    class="w-full h-full object-cover rounded-2xl group-hover:scale-105 transition-transform duration-500"
                                />
                            ) : (
                                <div class="w-full h-full bg-gray-50 rounded-2xl flex items-center justify-center">
                                    <span class="text-4xl text-gray-300">
                                        📰
                                    </span>
                                </div>
                            )}
                            <div class="absolute top-6 left-6 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-lg shadow-sm">
                                <span class="text-xs font-bold text-umb-verde uppercase">
                                    {new Date(
                                        noticia.frontmatter.date,
                                    ).toLocaleDateString("es-MX", {
                                        day: "2-digit",
                                        month: "short",
                                    })}
                                </span>
                            </div>
                        </div>

                        <div class="p-8 flex flex-col flex-grow">
                            <h2 class="text-xl font-bold text-gray-900 mb-3 line-clamp-3 group-hover:text-umb-verde transition-colors">
                                {noticia.frontmatter.title}
                            </h2>

                            <div class="mt-auto pt-4 flex items-center text-umb-verde font-semibold text-sm">
                                Leer artículo
                                <span class="ml-2 bg-green-100 w-8 h-8 rounded-full flex items-center justify-center group-hover:bg-umb-verde group-hover:text-white transition-colors">
                                    &rarr;
                                </span>
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>
    </main>
</Layout>
