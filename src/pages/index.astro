---
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<main
		class="relative min-h-screen flex items-center justify-center pt-32 pb-12 overflow-hidden bg-white"
	>
		<div
			class="absolute -top-20 -left-20 w-[600px] h-[600px] bg-umb-verde/15 z-0 animate-bubble"
			style="border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; animation-delay: 1s;"
		>
		</div>

		<div
			class="absolute top-10 -right-32 w-[750px] h-[750px] bg-umb-verde/15 z-0 animate-bubble"
			style="border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; animation-delay: 2s;"
		>
		</div>

		<div
			class="absolute -bottom-32 left-1/3 w-[450px] h-[450px] bg-umb-verde/10 z-0 animate-bubble"
			style="border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%; animation-delay: 0s;"
		>
		</div>

		<div
			class="container mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center px-6 relative z-10"
		>
			<div class="flex flex-col gap-6 z-10">
				<h1
					class="text-6xl md:text-7xl font-extrabold leading-[1.1] tracking-tighter text-gray-900"
				>
					Impulsa tu <br />
					<span class="text-umb-verde">futuro académico</span><br />
					al máximo nivel.
				</h1>
				<p
					class="text-lg text-gray-600 max-w-xl font-medium leading-relaxed"
				>
					Explora convocatorias actuales, nuestra oferta académica y
					todos los procesos de admisión de la Universidad Mexiquense
					del Bicentenario.
				</p>
				<div class="pt-6">
					<a
						href="/registro"
						class="inline-flex items-center gap-2 bg-umb-verde text-white px-10 py-4 rounded-full font-bold shadow-[0_10px_20px_rgba(127,178,57,0.3)] hover:shadow-[0_15px_25px_rgba(127,178,57,0.4)] hover:-translate-y-1 transition-all duration-300 text-lg group"
					>
						Inicia tu Proceso
						<span
							class="group-hover:translate-x-1 transition-transform"
							>🚀</span
						>
					</a>
				</div>
			</div>

			<div
				class="relative flex items-center justify-center z-10 w-full h-[650px] md:pr-10 overflow-visible"
			>
				<div
					class="relative w-max h-max flex items-center justify-center overflow-visible md:-ml-24"
				>
					<div
						class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[140%] h-[140%] bg-umb-verde/20 rounded-full blur-[70px] -z-10 animate-pulse"
					>
					</div>

					<div
						class="relative z-20 animate-bubble"
						style="animation-delay: 0s;"
					>
						<img
							src="/img/Estudiantes.jpg"
							alt="Estudiantes UMB"
							class="w-[420px] h-[520px] object-cover rounded-[3rem] shadow-2xl border-8 border-white"
						/>
					</div>

					<div
						class="absolute -left-24 top-4 z-40 bg-white px-5 py-4 rounded-2xl shadow-xl border border-gray-100 flex items-center gap-4 animate-bubble"
						style="animation-delay: 0.5s;"
					>
						<div
							class="bg-gray-100 p-2.5 rounded-full text-gray-700 text-xl"
						>
							🎓
						</div>
						<div class="flex flex-col">
							<span
								class="text-gray-900 font-extrabold text-2xl leading-none"
								>3</span
							>
							<span
								class="text-gray-500 font-bold text-xs uppercase tracking-wide"
								>Licenciaturas</span
							>
						</div>
					</div>

					<div
						class="absolute -left-20 bottom-10 z-30 animate-bubble"
						style="animation-delay: 1s;"
					>
						<img
							src="/img/estudiantemujer.png"
							alt="Estudiante UMB"
							class="w-40 h-40 object-cover rounded-3xl shadow-xl border-4 border-white bg-white"
						/>
					</div>

					<div
						class="absolute -right-20 top-[150px] z-30 animate-bubble"
						style="animation-delay: 1.5s;"
					>
						<img
							src="/img/estudiante.jpg"
							alt="Alumnos"
							class="w-44 h-44 object-cover rounded-full shadow-xl border-4 border-white"
						/>
					</div>

					<div
						class="absolute -right-16 -top-10 z-20 animate-bubble"
						style="animation-delay: 2s;"
					>
						<img
							src="/img/universidadmexiquense.jpg"
							alt="Campus UMB"
							class="w-56 h-40 object-cover rounded-2xl shadow-xl border-4 border-white"
						/>
					</div>

					<div
						class="absolute -right-16 bottom-10 z-40 bg-white px-5 py-4 rounded-2xl shadow-xl border border-gray-100 flex items-center gap-4 animate-bubble"
						style="animation-delay: 2.5s;"
					>
						<div
							class="bg-amber-100 p-2.5 rounded-full text-amber-600 text-xl"
						>
							🏆
						</div>
						<div class="flex flex-col">
							<span
								class="text-gray-900 font-extrabold text-base leading-none"
								>Calidad</span
							>
							<span
								class="text-gray-500 font-bold text-xs uppercase tracking-wide"
								>Académica</span
							>
						</div>
					</div>
				</div>
			</div>
		</div>
	</main>
</Layout>
